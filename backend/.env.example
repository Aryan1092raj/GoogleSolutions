# Backend runtime configuration (safe example; do not commit real secrets)

# Server
PORT=8080
LOG_LEVEL=info

# Firebase Admin (optional: backend also checks ./gcp-sa-key.json next to backend/)
# GOOGLE_APPLICATION_CREDENTIALS=D:/Projects/gdgsolutions/backend/gcp-sa-key.json
FIREBASE_DATABASE_URL=https://solution-e2a1c-default-rtdb.firebaseio.com

# Firebase Auth REST API key (required for /api/auth/staff-login)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Gemini live analysis
# Use either:
#   1. GEMINI_API_KEY + GEMINI_MODEL
#   2. GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION/VERTEX_AI_LOCATION + GEMINI_MODEL
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_LOCATION=us-central1

# Storage (required to finalize recordings)
GCS_BUCKET=your_gcs_bucket_name

# WebSocket tuning
WS_HEARTBEAT_INTERVAL_MS=30000
MAX_MEDIA_CHUNK_BYTES=524288

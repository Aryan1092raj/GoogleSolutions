# Google Maps API Key
# Get one from: console.cloud.google.com → APIs → Maps JavaScript API → Credentials
#
# Setup:
#   1. Copy this file to .env.local  (gitignored — your key stays private)
#   2. Paste your real API key below
#   3. Build with: cd dashboard && scripts\build-with-maps.bat
#      (This injects the key, builds, then restores the placeholder)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

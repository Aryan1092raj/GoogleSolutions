# Google Maps API Key
# Get one from: console.cloud.google.com → APIs → Maps JavaScript API → Credentials
#
# Setup:
#   1. Copy this file to .env.local  (gitignored — your key stays private)
#   2. Paste your real API key below
#   3. Run locally with: cd dashboard && scripts\run-with-maps.bat [device]
#      (This injects the key, runs Flutter Web, then restores the placeholder)
#      Example devices: edge, chrome, windows
#   4. Build release with: cd dashboard && scripts\build-with-maps.bat
#      (This injects the key, builds, then restores the placeholder)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GEMINI_API_KEY=your_actual_key
GEMINI_MODEL=gemini-2.0-flash
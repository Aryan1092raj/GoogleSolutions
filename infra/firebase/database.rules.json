{
  "rules": {
    "live_incidents": {
      "$hotelId": {
        ".read": "auth != null && (auth.token.hotelId == $hotelId || root.child('hotels/' + $hotelId + '/staff_online/' + auth.uid).exists())",
        ".write": false
      }
    },
    "live_frames": {
      "$incidentId": {
        ".read": "auth != null",
        ".write": false
      }
    },
    "hotels": {
      "$hotelId": {
        "staff_online": {
          ".read": "auth != null && (auth.token.hotelId == $hotelId || root.child('hotels/' + $hotelId + '/staff_online/' + auth.uid).exists())",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    }
  }
}
